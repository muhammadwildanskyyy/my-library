# =============================================================================
# AI Librarian Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://librarian:librarian_secret@db:5432/ai_librarian

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Active LLM Model ---
# Options: "openai" | "gemini"
ACTIVE_MODEL=openai

# --- API Keys ---
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
TAVILY_API_KEY=tvly-...

# --- Embedding ---
# OpenAI text-embedding-3-small = 1536
# Google text-embedding-004 = 768
EMBEDDING_DIMENSIONS=1536
EMBEDDING_MODEL=openai

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Chat Memory ---
SLIDING_WINDOW_TOKEN_LIMIT=4000
SLIDING_WINDOW_SUMMARIZE_COUNT=10
